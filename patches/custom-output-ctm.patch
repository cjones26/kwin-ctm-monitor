+static ValueRange matrixOutputRange(const QMatrix4x4 &matrix)
+{
+    double minimum = 0;
+    double maximum = 1;
+    for (int row = 0; row < 3; ++row) {
+        double rowMinimum = 0;
+        double rowMaximum = 0;
+        for (int column = 0; column < 3; ++column) {
+            const double coefficient = matrix(row, column);
+            rowMinimum += std::min(coefficient, 0.0);
+            rowMaximum += std::max(coefficient, 0.0);
+        }
+        minimum = std::min(minimum, rowMinimum);
+        maximum = std::max(maximum, rowMaximum);
+    }
+    return ValueRange{minimum, maximum};
+}
