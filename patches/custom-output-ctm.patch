+BackendOutput *DBusInterface::findOutput(const QString &selector) const
+{
+    const auto outputs = kwinApp()->outputBackend()->outputs();
+    const auto it = std::ranges::find_if(outputs, [&selector](BackendOutput *output) {
+        return output->name() == selector || output->uuid() == selector;
+    });
+    return it == outputs.end() ? nullptr : *it;
+}
+
+bool DBusInterface::applyOutputCtm(BackendOutput *output, const std::optional<QMatrix4x4> &matrix, bool store)
+{
+    if (!output) {
+        return false;
+    }
+    OutputConfiguration config;
+    config.source = OutputConfiguration::Source::User;
+    config.changeSet(output)->customSdrCtm = matrix;
+    return workspace()->applyOutputConfiguration(config, store) == OutputConfigurationError::None;
+}
+
+QString DBusInterface::outputCtmState()
+{
+    QJsonArray result;
+    for (BackendOutput *output : kwinApp()->outputBackend()->outputs()) {
+        QJsonObject item{{"name", output->name()}, {"uuid", output->uuid()}, {"hdr", output->highDynamicRange()}};
+        if (output->customSdrCtm()) {
+            QJsonArray values;
+            for (int row = 0; row < 3; ++row) {
+                for (int column = 0; column < 3; ++column) {
+                    values.push_back((*output->customSdrCtm())(row, column));
+                }
+            }
+            item["matrix"] = values;
+        }
+        result.push_back(item);
+    }
+    return QString::fromUtf8(QJsonDocument(result).toJson(QJsonDocument::Compact));
+}
+
+QString DBusInterface::beginOutputCtmTest(const QString &selector, const QString &encoded, uint timeoutSeconds)
+{
+    if (!m_ctmTestToken.isEmpty()) {
+        sendErrorReply(QDBusError::LimitsExceeded, QStringLiteral("another CTM test is active"));
+        return {};
+    }
+    BackendOutput *output = findOutput(selector);
+    const QStringList parts = encoded.split(QLatin1Char(','));
+    if (!output || parts.size() != 9 || timeoutSeconds < 5 || timeoutSeconds > 120) {
+        sendErrorReply(QDBusError::InvalidArgs, QStringLiteral("invalid output, matrix, or timeout"));
+        return {};
+    }
+    QMatrix4x4 matrix;
+    for (int index = 0; index < 9; ++index) {
+        bool ok = false;
+        const double value = parts[index].toDouble(&ok);
+        if (!ok || !std::isfinite(value) || std::abs(value) > 8) {
+            sendErrorReply(QDBusError::InvalidArgs, QStringLiteral("matrix coefficients must be finite and within [-8, 8]"));
+            return {};
+        }
+        matrix(index / 3, index % 3) = value;
+    }
+    m_ctmTestOutput = output;
+    m_previousCtm = output->customSdrCtm();
+    m_ctmTestToken = QUuid::createUuid().toString(QUuid::WithoutBraces);
+    if (!applyOutputCtm(output, matrix, false)) {
+        m_ctmTestOutput.clear();
+        m_previousCtm.reset();
+        m_ctmTestToken.clear();
+        sendErrorReply(QDBusError::Failed, QStringLiteral("the DRM backend rejected the CTM"));
+        return {};
+    }
+    m_ctmRollbackTimer.start(int(timeoutSeconds * 1000));
+    return m_ctmTestToken;
+}
+
+bool DBusInterface::confirmOutputCtmTest(const QString &token)
+{
+    if (token != m_ctmTestToken || !m_ctmTestOutput) {
+        return false;
+    }
+    m_ctmRollbackTimer.stop();
+    workspace()->outputConfigureStore()->storeConfig(kwinApp()->outputBackend()->outputs(), false);
+    m_ctmTestOutput.clear();
+    m_previousCtm.reset();
+    m_ctmTestToken.clear();
+    return true;
+}
+
+void DBusInterface::rollbackOutputCtm()
+{
+    if (m_ctmTestOutput) {
+        applyOutputCtm(m_ctmTestOutput, m_previousCtm, false);
+    }
+    m_ctmRollbackTimer.stop();
+    m_ctmTestOutput.clear();
+    m_previousCtm.reset();
+    m_ctmTestToken.clear();
+}
+
+bool DBusInterface::cancelOutputCtmTest(const QString &token)
+{
+    if (token != m_ctmTestToken) {
+        return false;
+    }
+    rollbackOutputCtm();
+    return true;
+}
+
+bool DBusInterface::resetOutputCtm(const QString &selector)
+{
+    return m_ctmTestToken.isEmpty() && applyOutputCtm(findOutput(selector), std::nullopt, true);
+}
+
 bool DBusInterface::showingDesktop() const
 {
     return workspace()->showingDesktop();
